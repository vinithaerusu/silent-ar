# Copy to ".env" and add your key (the .env file is gitignored).
# Get a FREE key at https://aistudio.google.com/apikey

GEMINI_API_KEY=your_free_gemini_key_here

# optional — defaults to gemini-3.1-flash-lite (vision, free tier, ~500 requests/day)
# want higher quality? try gemini-2.5-flash (nicer, but only ~20 requests/day)
# GEMINI_MODEL=gemini-3.1-flash-lite
